# Anthropic API key — required for the demo agent (demo/coding-agent.ts)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# URL of your deployed Loci Worker — required for run-with-loci.ts
# After `npx wrangler deploy`, copy the printed URL here
LOCI_API_URL=https://loci.<your-subdomain>.workers.dev
